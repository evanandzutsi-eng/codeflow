# ============================================================================
# CodeFlow — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control — it's in .gitignore.
#
# OWASP A02:2021 — Cryptographic Failures:
#   All secrets MUST be in environment variables, never hard-coded.
# ============================================================================

# ── Server Configuration ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
TRUST_PROXY=false

# ── CORS — Allowed frontend origins (comma-separated) ────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── CSRF Cookie Signing Secret ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=CHANGE_ME_generate_a_64_char_hex_string

# ── Email Service API Key (SendGrid, Mailchimp, Resend, etc.) ────────────────
# Used server-side only for newsletter subscriptions.
# NEVER expose this to the frontend / client-side code.
EMAIL_SERVICE_API_KEY=your_email_service_api_key_here

# ── AI Service API Key (OpenAI, Anthropic, etc.) ─────────────────────────────
# Used server-side only for the /api/generate endpoint.
# NEVER expose this to the frontend / client-side code.
AI_SERVICE_API_KEY=your_ai_service_api_key_here

# ── Database URL (future use) ────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/codeflow

# ── Session Secret (future use for auth) ─────────────────────────────────────
# SESSION_SECRET=CHANGE_ME_generate_another_64_char_hex_string

# ============================================================================
# KEY ROTATION CHECKLIST:
# ============================================================================
# 1. Rotate COOKIE_SECRET     → every 90 days or after suspected compromise
# 2. Rotate EMAIL_SERVICE_KEY  → every 90 days, revoke old key in provider dashboard
# 3. Rotate AI_SERVICE_API_KEY → every 90 days, revoke old key in provider dashboard
# 4. Rotate SESSION_SECRET     → every 90 days (will invalidate active sessions)
#
# Use a secrets manager in production (AWS Secrets Manager, Vault, Doppler).
# ============================================================================
